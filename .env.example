# DobbyAI Multi-Agent Mortgage Demo — environment template
#
# Copy this file to .env and fill in your inference endpoint credentials.
# The demo uses an Anthropic-format Messages API endpoint — any of:
#   - Anthropic API directly
#   - DobbyAI proxy (api.palomaressoftware.com/dobbyai/v1/messages)
#   - LiteLLM, OpenRouter, or any other Anthropic-compatible proxy
#
# Two variable-name conventions are accepted (the code checks DOBBYAI_* first,
# then falls back to AGENT_* for compatibility with claude-code-simple's .env):

# ─── Option A: DobbyAI proxy / on-prem (recommended for production-shape demo)
DOBBYAI_API_URL=https://api.palomaressoftware.com/dobbyai/v1/messages
DOBBYAI_API_KEY=dk_PASTE_YOUR_DOBBYAI_KEY

# Tiered model strategy (Lesson 14 / Mortgage demo):
#   DOBBYAI_MODEL           — workers + decompose. Sonnet alias → Qwen3.6-35B-A3B on GX10:8082
#                             Fast MoE, 3B active params, 3-5s decode per worker call.
#   DOBBYAI_AGGREGATE_MODEL — final synthesis. Opus alias → gpt-oss-120b on GX10:8080
#                             Bigger model for the one expensive call (decision document).
DOBBYAI_MODEL=claude-sonnet-4-20250514
DOBBYAI_AGGREGATE_MODEL=claude-opus-4-20250514

# Thinking mode for the aggregate call (the orchestrator's final synthesis).
#   ON  (default): visible <think> block → final document. Slower (~45s),
#                  but the reasoning chain IS the demo's compliance gold.
#                  Uses max_tokens=8192.
#   OFF:           clean decision document only. Faster (~15s).
#                  Uses max_tokens=4096.
# Workers ALWAYS run thinking OFF — they're 19 narrow JSON verifiers,
# reasoning is wasted compute there.
# DOBBYAI_AGGREGATE_THINKING=true

# ─── Option B: Anthropic direct (uncomment + comment out Option A)
# DOBBYAI_API_URL=https://api.anthropic.com/v1/messages
# DOBBYAI_API_KEY=sk-ant-PASTE_YOUR_ANTHROPIC_KEY
# DOBBYAI_MODEL=claude-sonnet-4-5-20250929

# ─── Option C: any Anthropic-compatible OpenAI-style proxy
# DOBBYAI_API_URL=https://YOUR_PROXY/v1/messages
# DOBBYAI_API_KEY=your-key
# DOBBYAI_MODEL=claude-sonnet-4-20250514

# ─── Tasks database path (default tasks.db in cwd)
# TASKS_DB_PATH=/var/dobbyai/tasks.db

# ─── OAuth + Tasks server URLs (defaults match local dev)
# OAUTH_TOKEN_URL=http://localhost:3300/token
# TASKS_MCP_URL=http://localhost:3500/mcp
# TASKS_RESOURCE=http://localhost:3500
